{
  "name": "tailored",
  "private": true,
  "scripts": {
    "dev": "pnpm -F @tailored/web dev",
    "build": "pnpm -F @tailored/db build && pnpm -F @tailored/agents build && pnpm -F @tailored/web build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "pnpm -F @tailored/db run migrate",
    "db:seed": "pnpm -F @tailored/db run seed",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
