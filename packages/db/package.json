{
  "name": "@tailored/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "migrate": "prisma migrate dev",
    "seed": "prisma db seed",
    "postinstall": "node -e \"if(process.env.DATABASE_URL){require('child_process').execSync('prisma generate',{stdio:'inherit'})}else{console.log('Skipping prisma generate: set DATABASE_URL first')}\""
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "prisma": "^6.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.2.0"
  },
  "prisma": {
    "schema": "prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts"
  }
}
