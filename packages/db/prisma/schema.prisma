generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id             String   @id @default(cuid())
  cv             String
  salaryMin      Int?
  salaryMax      Int?
  location       String?
  workType       String?  // "remote"|"hybrid"|"onsite"
  scoringWeights String   // JSON object
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Identity
  fullName         String?
  email            String?
  phone            String?
  linkedin         String?
  portfolioUrl     String?
  github           String?
  twitter          String?

  // Narrative
  headline         String?
  exitStory        String?
  superpowers      String?   // JSON string[]

  // Compensation extras
  currency              String?
  salaryFloor           Int?
  locationFlexibility   String?

  // Location / auth
  timezone          String?
  visaStatus        String?
  onsiteAvailability String?

  // Proof points
  proofPoints      String?   // JSON array: [{name, url, heroMetric}]

  // Target roles
  roleTargets      String?   // JSON array: [{title, priority, seniority, pitchWhen?}]

  // CV output
  cvFormat         String?   // "html"|"latex"
  canvaDesignId    String?
  autoPdfThreshold Float?
}

model DiscoveryPrefs {
  id             String   @id @default(cuid())
  portals        String   // JSON string[] of portal keys
  keywords       String   // JSON string[]
  titleFilter    String?  // JSON: {derived: string[], custom: string[], negative: string[], seniorityBoost: string[]}
  locationFilter String?  // JSON: {derived: string[], allow: string[], block: string[], alwaysAllow: string[]}
  minScore       String?  // "A"|"B"|"C"|"D"|"F"
  updatedAt      DateTime @updatedAt
}

model ResumePrefs {
  id           String   @id @default(cuid())
  template     String   @default("default")
  sectionOrder String   // JSON string[]
  tone         String?
  keywords     String   // JSON string[]
  updatedAt    DateTime @updatedAt
}

model Job {
  id          String   @id @default(cuid())
  company     String
  role        String
  url         String?  @unique
  source      String   // "direct"|"scan"
  archetype   String?
  score       String?  // "A"|"B+"|"B"|"C"|"D"|"F"
  cvMatchPct  Int?
  evalReport  String?  // JSON: 6-block report object
  status      String   @default("new")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  resumes     GeneratedResume[]
}

model GeneratedResume {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  filename  String
  path      String
  createdAt DateTime @default(now())
}

model CustomPortal {
  id        String   @id @default(cuid())
  name      String
  url       String
  enabled   Boolean  @default(true)
  provider  String?  // "Ashby"|"Greenhouse"|"Lever"|"Workable"|"SmartRecruiters"|"Recruitee"
  api       String?  // alternate API endpoint URL
  notes     String?  // user-facing context shown in the tile
  createdAt DateTime @default(now())
}

model SearchQuery {
  id        String   @id @default(cuid())
  name      String
  query     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
}
