{
  "name": "@tailored/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "tailored": "./dist/index.cjs"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/index.cjs \"--banner:js=#!/usr/bin/env node\" --external:@prisma/client --external:playwright --external:playwright-core --external:chromium-bidi --external:fsevents",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.54",
    "@prisma/client": "^6.9.0",
    "@tailored/agents": "workspace:*",
    "@tailored/db": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "ora": "^5.4.1",
    "playwright": "^1.60.0",
    "rxjs": "7.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.0"
  }
}
